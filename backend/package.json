{
  "name": "jl-autos-backend",
  "version": "1.0.0",
  "description": "High-end corporate backend for J&L Autos car dealership platform",
  "main": "server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "npx prisma generate && npx prisma db push --accept-data-loss && node dist/app.js",
    "migrate": "prisma migrate dev",
    "seed": "ts-node src/prisma/seed.ts",
    "setup": "prisma generate && prisma db push && npm run seed"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.2",
    "glob": "^11.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.3",
    "nodemailer": "^6.9.11",
    "pdfkit": "^0.15.0",
    "pm2": "^7.0.1",
    "prisma": "^5.10.2",
    "rimraf": "^4.4.1",
    "sharp": "^0.33.2",
    "ts-node-dev": "^2.0.0",
    "twilio": "^6.0.2",
    "typescript": "^5.3.3",
    "uuid": "^11.1.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
