{
  "name": "jl-autos-backend",
  "version": "1.0.0",
  "description": "High-end corporate backend for J&L Autos car dealership platform",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "ts-node src/prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "setup": "prisma generate && prisma db push && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.4",
    "@types/winston": "^2.4.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.3",
    "nodemailer": "^6.10.1",
    "path": "^0.12.7",
    "pdfkit": "^0.17.2",
    "prisma": "^5.10.2",
    "sharp": "^0.33.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "twilio": "^6.0.2",
    "typescript": "^5.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {}
}
