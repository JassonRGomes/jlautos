# ─────────────────────────────────────────────────────────────────
# J&L AUTOS — BACKEND ENVIRONMENT CONFIGURATION (EXEMPLO)
# ─────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA envie o .env real para o GitHub.
# -----------------------------------------------------------------

# ─── SERVIDOR ────────────────────────────────────────────────────
PORT=5001
NODE_ENV="production"

# ─── BANCO DE DADOS (MySQL — Hostinger hPanel) ───────────────────
# Formato: mysql://USUARIO:SENHA@HOST:3306/NOME_DO_BANCO
DATABASE_URL="mysql://SEU_USUARIO:SUA_SENHA@SEU_HOST:3306/SEU_BANCO"

# ─── AUTENTICAÇÃO JWT ─────────────────────────────────────────────
# Use uma string longa e aleatória
JWT_SECRET="CHAVE_SECRETA_LONGA_E_ALEATORIA"

# ─── FRONTEND ────────────────────────────────────────────────────
FRONTEND_URL="https://seusite.hostingersite.com"
REVALIDATION_TOKEN="SEU_TOKEN_DE_REVALIDACAO"

# ─── EMAIL (Nodemailer) ───────────────────────────────────────────
EMAIL_SMTP_HOST="smtp.seudominio.com.br"
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER="contato@seudominio.com.br"
EMAIL_SMTP_PASS="SUA_SENHA_DE_EMAIL"
AGENCY_EMAIL="vendas@seudominio.com.br"

# ─── TWILIO SMS (Opcional) ────────────────────────────────────────
TWILIO_ACCOUNT_SID="COLE_SEU_ACCOUNT_SID_AQUI"
TWILIO_AUTH_TOKEN="COLE_SEU_AUTH_TOKEN_AQUI"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"
AGENCY_PHONE_NUMBER="+XXXXXXXXXXX"
SMS_ENABLED="false"
