// J&L Autos — Prisma Schema
// Database: SQLite for development, PostgreSQL for production
//
// To switch to PostgreSQL:
//   1. Set provider = "postgresql" in datasource
//   2. Set DATABASE_URL to your PostgreSQL connection string
//   3. Change Float fields to Decimal @db.Decimal(12,2)
//   4. Run: npx prisma migrate dev

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

// ─── User Model ───────────────────────────────────────────────────────────────
// Roles: ADMIN | SALES_REP | CUSTOMER
model User {
  id            String      @id @default(uuid())
  email         String      @unique
  passwordHash  String
  name          String
  phone         String?
  image         String?
  role          String      @default("CUSTOMER") // "CUSTOMER" | "SALES_REP" | "ADMIN"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bookings      Booking[]
  testDrives    TestDrive[] @relation("CustomerTestDrives")
  salesTestDrives TestDrive[] @relation("SalesRepTestDrives")
  offers        Offer[]
  favorites     Favorite[]
  savedSearches SavedSearch[]
  activityLogs  ActivityLog[]
}

// ─── Vehicle Inventory Model ──────────────────────────────────────────────────
model Vehicle {
  id                      String            @id @default(uuid())
  make                    String
  model                   String
  year                    Int
  color                   String
  mileage                 Int
  price                   Float
  transmission            String            // "Automatic" | "Manual"
  engine                  String
  fuelType                String            // "Gasoline" | "Diesel" | "Electric" | "Hybrid"
  bodyStyle               String            // "Sedan" | "SUV" | "Coupe" | "Convertible"
  seats                   Int
  doors                   Int
  vin                     String?           @unique
  description             String
  status                  String            @default("ON_SALE") // "ON_SALE" | "RESERVED" | "SOLD"
  images                  String            // JSON string array
  isFinanceWarrantyActive Boolean           @default(false)
  financeData             String?           // JSON: downpayment, rates, terms
  warrantyData            String?           // JSON: duration, coverage
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  bookings                Booking[]
  testDrives              TestDrive[]
  offers                  Offer[]
  favorites               Favorite[]
  newsletterBlasts        NewsletterBlast[]
}

// ─── Booking Model (Showroom Visit + Test Drive appointments) ─────────────────
model Booking {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date      DateTime
  timeSlot  String   // "10:00 AM" | "02:00 PM"
  eventType String   // "VISIT" | "TEST_DRIVE"
  status    String   @default("PENDING") // "PENDING" | "CONFIRMED" | "CANCELED" | "COMPLETED"
  notes     String?  // Optional customer/admin notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Test Drive Model (Dedicated, with Sales Rep) ────────────────────────────
model TestDrive {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation("CustomerTestDrives", fields: [userId], references: [id], onDelete: Cascade)
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  salesRepId      String?
  salesRep        User?    @relation("SalesRepTestDrives", fields: [salesRepId], references: [id], onDelete: SetNull)
  testDriveDate   DateTime
  testDriveTime   String   // "10:00 AM" | "03:00 PM"
  location        String   @default("Dealership") // "Dealership" | "Customer Address" | custom
  status          String   @default("SCHEDULED")  // "SCHEDULED" | "APPROVED" | "COMPLETED" | "CANCELED" | "NO_SHOW"
  notes           String?
  adminNotes      String?  // Internal staff-only notes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Activity Log ─────────────────────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(uuid())
  action      String   // "BOOKING_CREATED" | "BOOKING_CONFIRMED" | "TEST_DRIVE_SCHEDULED" | etc.
  entityType  String   // "Booking" | "TestDrive" | "Vehicle" | "User"
  entityId    String
  performedBy String   // User ID
  user        User     @relation(fields: [performedBy], references: [id], onDelete: Cascade)
  metadata    String?  // JSON: additional context
  createdAt   DateTime @default(now())
}

// ─── Client Price Offers Pipeline ────────────────────────────────────────────
model Offer {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  offerAmount Float
  status      String   @default("UNDER_REVIEW") // "UNDER_REVIEW" | "ACCEPTED" | "DECLINED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Favorites / Wishlist ─────────────────────────────────────────────────────
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, vehicleId])
}

// ─── Saved Search Filter Matrices ────────────────────────────────────────────
model SavedSearch {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  queryParams String   // JSON string of query parameters
  createdAt   DateTime @default(now())
}

// ─── Global Dealership Metadata ───────────────────────────────────────────────
model GlobalSettings {
  id             String   @id @default("global")
  address        String
  phone          String
  whatsappNumber String
  operatingHours String   // JSON string
  logoUrl        String?
  updatedAt      DateTime @updatedAt
}

// ─── Newsletter Blast Logs ────────────────────────────────────────────────────
model NewsletterBlast {
  id             String   @id @default(uuid())
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  sentAt         DateTime @default(now())
  recipientCount Int
}
