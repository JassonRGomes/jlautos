datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordHash        String
  name                String
  phone               String?
  image               String?
  role                String   @default("CUSTOMER") // ADMIN, MANAGER, SALES, CUSTOMER
  forcePasswordChange Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sales              Sale[]
  stockMovements     StockMovement[]
  sessions           Session[]
  bookings           Booking[]
  favorites          Favorite[]
  savedSearches      SavedSearch[]
  offers             Offer[]
  customerTestDrives TestDrive[]   @relation("CustomerTestDrives")
  salesTestDrives    TestDrive[]   @relation("SalesRepTestDrives")
  activityLogs       ActivityLog[] @relation("UserActivityLogs")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @db.Text
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?
  document  String?  @unique
  address   String?
  city      String?
  state     String?
  zipCode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]
}

model Vehicle {
  id                     String   @id @default(uuid())
  make                   String
  model                  String
  year                   Int
  color                  String   @default("Black")
  mileage                Int      @default(0)
  price                  Decimal  @db.Decimal(12, 2)
  vin                    String?  @unique
  status                 String   @default("ON_SALE") // ON_SALE, SOLD, RESERVED, MAINTENANCE
  images                 String   @db.Text // JSON array of URLs
  description            String?  @db.Text
  transmission           String?
  engine                 String?
  fuelType               String?
  bodyStyle              String?
  seats                  Int?
  doors                  Int?
  isFinanceWarrantyActive Boolean @default(false)
  financeData            String?  @db.Text // JSON
  warrantyData           String?  @db.Text // JSON
  features               String?  @db.Text // JSON array
  dealershipId           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  dealership Dealership? @relation(fields: [dealershipId], references: [id])
  saleItems  SaleItem[]
  bookings   Booking[]
  testDrives TestDrive[]
  favorites  Favorite[]
  offers     Offer[]

  @@index([make])
  @@index([status])
  @@index([price])
  @@index([year])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  vehicleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
}

model SavedSearch {
  id          String   @id @default(uuid())
  userId      String
  name        String
  queryParams String   @db.Text // JSON
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  document  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  sku         String   @unique
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  costPrice   Decimal  @db.Decimal(12, 2)
  stock       Int      @default(0)
  categoryId  Int
  supplierId  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       Category        @relation(fields: [categoryId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[]
  saleItems      SaleItem[]
}

model StockMovement {
  id        String   @id @default(uuid())
  productId String
  userId    String
  type      String   // IN, OUT, ADJUSTMENT
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model Sale {
  id          String   @id @default(uuid())
  customerId  String
  userId      String
  totalAmount Decimal  @db.Decimal(12, 2)
  status      String   @default("PENDING") // PENDING, COMPLETED, CANCELED
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer     Customer               @relation(fields: [customerId], references: [id])
  user         User                   @relation(fields: [userId], references: [id])
  items        SaleItem[]
  transactions FinancialTransaction[]
}

model SaleItem {
  id         String   @id @default(uuid())
  saleId     String
  vehicleId  String?
  productId  String?
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(12, 2)
  totalPrice Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
}

model FinancialTransaction {
  id          String    @id @default(uuid())
  saleId      String?
  type        String    // INCOME, EXPENSE
  amount      Decimal   @db.Decimal(12, 2)
  status      String    @default("PENDING") // PENDING, PAID, CANCELED
  dueDate     DateTime?
  paidDate    DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sale Sale? @relation(fields: [saleId], references: [id])
}

model Booking {
  id                 String   @id @default(uuid())
  userId             String
  vehicleId          String
  dealershipId       String?
  availabilitySlotId String?
  bookingDate        DateTime
  bookingTime        String
  status             String   @default("pending") // pending, confirmed, completed, cancelled
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  dealership       Dealership?       @relation(fields: [dealershipId], references: [id])
  availabilitySlot AvailabilitySlot? @relation(fields: [availabilitySlotId], references: [id])
}

model TestDrive {
  id                    String   @id @default(uuid())
  userId                String
  vehicleId             String
  dealershipId          String?
  availabilitySlotId    String?
  salesRepresentativeId String?
  testDriveDate         DateTime
  testDriveTime         String
  location              String   @default("Dealership")
  status                String   @default("scheduled") // scheduled, approved, completed, cancelled, no-show
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user             User              @relation("CustomerTestDrives", fields: [userId], references: [id], onDelete: Cascade)
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  salesRep         User?             @relation("SalesRepTestDrives", fields: [salesRepresentativeId], references: [id], onDelete: SetNull)
  dealership       Dealership?       @relation(fields: [dealershipId], references: [id])
  availabilitySlot AvailabilitySlot? @relation(fields: [availabilitySlotId], references: [id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  performedBy String
  createdAt   DateTime @default(now())

  user User @relation("UserActivityLogs", fields: [performedBy], references: [id], onDelete: Cascade)
}

model Dealership {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phone          String?
  whatsappNumber String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  logoUrl        String?
  operatingHours String?  @db.Text // JSON string
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicles         Vehicle[]
  bookings         Booking[]
  testDrives       TestDrive[]
  availabilitySlots AvailabilitySlot[]
}

model AvailabilitySlot {
  id           String   @id @default(uuid())
  dealershipId String
  date         DateTime
  startTime    String   // e.g., "09:00"
  endTime      String   // e.g., "10:00"
  isBooked     Boolean  @default(false)
  type         String   @default("TEST_DRIVE") // TEST_DRIVE, SERVICE, CONSULTATION
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  bookings   Booking[]
  testDrives TestDrive[]
}

model Offer {
  id          String   @id @default(uuid())
  userId      String
  vehicleId   String
  offerAmount Decimal  @db.Decimal(12, 2)
  status      String   @default("UNDER_REVIEW") // UNDER_REVIEW, ACCEPTED, DECLINED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}
