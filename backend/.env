# ─────────────────────────────────────────────────────────────────
# J&L AUTOS — BACKEND ENVIRONMENT CONFIGURATION
# ─────────────────────────────────────────────────────────────────
# Renomeie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA envie o .env real para o GitHub.
# -----------------------------------------------------------------

# ─── SERVIDOR ────────────────────────────────────────────────────
# Porta onde a API será executada (Hostinger costuma usar 3001 ou a porta que você configurar)
PORT=5001

# Ambiente de execução: "production" no servidor, "development" local
NODE_ENV="production"

# ─── BANCO DE DADOS (MySQL — Hostinger hPanel) ───────────────────
# Formato: mysql://u373012508_jlautos:2312Joyc&@localhost:3306/u373012508_jassongomes
# As credenciais são encontradas no hPanel > Bancos de Dados > MySQL
DATABASE_URL="mysql://u373012508_jlautos:2312Joyc%26@localhost:3306/u373012508_jassongomes"

# ─── AUTENTICAÇÃO JWT ─────────────────────────────────────────────
# Chave secreta para assinar os tokens JWT. Use uma string longa e aleatória.
JWT_SECRET="jesus_is_love"

# ─── FRONTEND & REVALIDAÇÃO ───────────────────────────────────────
# URL completa do seu domínio principal (sem barra no final)
FRONTEND_URL="https://lightcyan-shark-136321.hostingersite.com"

# Token secreto para revalidar o cache do Next.js remotamente
REVALIDATION_TOKEN="god_is_good"

# ─── EMAIL (Nodemailer) ───────────────────────────────────────────
# Configure com seu provedor de email real (ex: SendGrid, Brevo, Gmail SMTP)
EMAIL_SMTP_HOST="smtp.seudominio.com.br"
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER="contato@seudominio.com.br"
EMAIL_SMTP_PASS="SUA_SENHA_DE_EMAIL"
AGENCY_EMAIL="vendas@seudominio.com.br"

# ─── TWILIO SMS (Opcional) ────────────────────────────────────────
# Obtenha as credenciais em: https://console.twilio.com
# Deixe "false" em SMS_ENABLED para desativar sem remover as variáveis.
TWILIO_ACCOUNT_SID="COLE_SEU_ACCOUNT_SID_AQUI"
TWILIO_AUTH_TOKEN="COLE_SEU_AUTH_TOKEN_AQUI"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# Número de telefone da concessionária (formato E.164)
AGENCY_PHONE_NUMBER="+XXXXXXXXXXX"

# Ativar/desativar o envio de SMS globalmente
SMS_ENABLED="false"
